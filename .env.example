# 平台后端
HOST=0.0.0.0
PORT=8000
OPC_SECRET_KEY=please-change-to-a-long-random-secret
ALLOW_ORIGINS=*

# 远程 PostgreSQL，二选一：
DATABASE_URL=postgresql://opc:your_password@42.192.112.233:5432/opc_tryon

# 或使用拆分配置，未设置 DATABASE_URL 时生效：
POSTGRES_HOST=42.192.112.233
POSTGRES_PORT=5432
POSTGRES_DB=opc_tryon
POSTGRES_USER=opc
POSTGRES_PASSWORD=your_password

# 外部生成服务，即 service.py 或外部部署的换衣/单图编辑服务
TRYON_SERVICE_URL=http://42.192.112.233:8008

# 如果本仓库同时部署 service.py，可用下列配置对接 zealman/ComfyUI 面板
COMFY_PANEL_BASE_URL=https://your-comfy-panel.example.com
TRYON_WORKFLOW_ID=HZ
SINGLE_IMAGE_WORKFLOW_ID=F01-FireRed-Image-Edit-1-single-image-optimized

# 本地联调可设为 true，不调用远程换装模型，直接返回示例图
OPC_MOCK_TRYON=false
